---
import Layout from '../layouts/Layout.astro';

const locations = [
  { id: 'naha', name: '那覇エリア (配彩なは)', text: '那覇市・浦添市・豊見城市周辺の配達スタッフおよび厨房スタッフを募集しています。' },
  { id: 'awase', name: '泡瀬エリア (配彩あわせ)', text: '沖縄市周辺の配達スタッフを募集しています。' },
  { id: 'onna', name: '恩納エリア (配彩ナビィー)', text: '恩納村周辺の配達スタッフを募集しています。' },
  { id: 'nago', name: '名護エリア (配彩やんばる)', text: '名護市周辺の調理補助・配達スタッフを募集しています。' }
];
const base = import.meta.env.BASE_URL;
---

<Layout title="採用情報 | 沖縄県高齢者協同組合" description="沖縄県内4拠点（那覇・泡瀬・恩納・名護）で、お弁当の配達や調理補助などのスタッフを募集しています。">
  <div class="page-header" style={`background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6)), url('${base}images/image_5.jpg');`}>
    <div class="container text-center">
      <h1 class="page-title">採用情報</h1>
      <p class="page-subtitle">地域に笑顔を届ける、やりがいのあるお仕事です</p>
    </div>
  </div>

  <section class="section pt-3">
    <div class="container">
      
      <div class="text-center mb-5">
        <h2 class="sub-heading">現在募集中のエリア</h2>
        <p class="text-light-gray">
          沖縄県内全4エリアの事業所で、一緒に働く仲間を募集しています。<br class="pc-br"/>
          ご希望の勤務地（エリア）をご覧ください。
        </p>
        
        <!-- Quick Nav -->
        <div class="area-nav">
          {locations.map(loc => (
            <a href={`#${loc.id}`} class="btn btn-primary">{loc.name.split(' ')[0]}</a>
          ))}
        </div>
      </div>

      <div class="recruit-list">
        
        {locations.map((loc) => (
          <div id={loc.id} class="recruit-card">
            <div class="card-header">
              <h3>{loc.name}</h3>
            </div>
            <div class="card-body">
              <p class="intro">{loc.text}</p>
              
              <table class="job-table">
                <tbody>
                  <tr>
                    <th>募集職種</th>
                    <td>お弁当の配達スタッフ / 厨房（調理補助）スタッフ</td>
                  </tr>
                  <tr>
                    <th>勤務地</th>
                    <td>【{loc.name.split(' ')[0]}】該当事業所からご自宅までの距離等を考慮</td>
                  </tr>
                  <tr>
                    <th>勤務時間</th>
                    <td>9:00〜18:00の内、1日4時間〜（応相談）<br/><small>※土曜・祝日出勤可能な方歓迎、日曜休み</small></td>
                  </tr>
                  <tr>
                    <th>給与・時給</th>
                    <td>詳細は面接時、またはお電話にてお問い合わせください</td>
                  </tr>
                  <tr>
                    <th>待遇・福利厚生</th>
                    <td>交通費規定支給、制服貸与、まかない付き（応相談）</td>
                  </tr>
                </tbody>
              </table>

              <div class="action-area text-center mt-4">
                <p>このエリアの求人について、まずはご相談・ご応募ください</p>
                <div class="mt-3">
                  <a href={base + "contact"} class="btn btn-secondary btn-large">ネットから応募・問い合わせする</a>
                </div>
              </div>

            </div>
          </div>
        ))}

      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    height: 300px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    color: var(--color-white);
    margin-bottom: 40px;
  }
  .page-title { font-size: 2.5rem; margin-bottom: 10px; font-weight: 700; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
  .page-subtitle { font-size: 1.2rem; text-shadow: 0 1px 2px rgba(0,0,0,0.5); }
  .text-center { text-align: center; }
  .mb-5 { margin-bottom: 50px; }
  .mt-3 { margin-top: 15px; }
  .mt-4 { margin-top: 30px; }
  .pt-3 { padding-top: 30px; }
  .text-light-gray { color: var(--color-text-light); }
  .pc-br { display: block; }

  .sub-heading { color: var(--color-primary-dark); font-size: 1.8rem; margin-bottom: 15px; }

  /* Quick Nav */
  .area-nav {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  /* Recruit list */
  .recruit-list {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .recruit-card {
    background: var(--color-white);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    scroll-margin-top: 100px; /* offset for sticky header */
    border: 1px solid var(--color-border);
  }

  .card-header {
    background-color: var(--color-bg-alt);
    padding: 20px 30px;
    border-bottom: 2px solid var(--color-primary-light);
  }
  .card-header h3 {
    margin: 0;
    font-size: 1.5rem;
    color: var(--color-primary-dark);
  }

  .card-body {
    padding: 30px;
  }
  .intro {
    font-size: 1.1rem;
    margin-bottom: 25px;
    color: var(--color-text);
  }

  .job-table {
    width: 100%;
    border-collapse: collapse;
  }
  .job-table th, .job-table td {
    padding: 15px;
    border-bottom: 1px dashed var(--color-border);
    text-align: left;
    vertical-align: top;
  }
  .job-table th {
    width: 25%;
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .action-area {
    background-color: var(--color-bg);
    padding: 30px;
    border-radius: 8px;
    margin-top: 30px;
  }

  .btn-large {
    padding: 15px 40px;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .page-title { font-size: 2rem; }
    .pc-br { display: none; }
    .area-nav { gap: 10px; }
    .job-table th, .job-table td { display: block; width: 100%; }
    .job-table th { border-bottom: none; padding-bottom: 5px; color: var(--color-primary); }
    .job-table td { padding-top: 0; padding-bottom: 20px; border-bottom: 1px dashed var(--color-border); }
    .btn-large { width: 100%; padding: 15px 10px; }
  }
</style>
